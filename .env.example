# ==========================================
# OPENCLAW AGENT CONFIGURATION
# ==========================================

# Выбор LLM модели для принятия решений агентом
# Используем OpenRouter для Pay-as-you-go. 
# На этапе тестирования (MVP) используем бесплатные/ультрадешевые модели.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Основная модель агента (для простых задач и парсинга)
AGENT_FAST_MODEL=minimax/minimax-v2.5
# Умная модель агента (для финальных финансовых решений, если потребуется)
AGENT_SMART_MODEL=minimax/minimax-v2.5

# ==========================================
# INFRASTRUCTURE & ENVIRONMENT
# ==========================================
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Пути внутри Docker-контейнера
DATA_DIR=/app/data
SKILLS_DIR=/app/skills
PROMPTS_DIR=/app/prompts

# ==========================================
# EXTERNAL APIs (Будут нужны позже)
# ==========================================
# Telegram Bot API Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# MOEX ISS API (Бесплатно, ключ не нужен, но можно указать лимиты)
MOEX_API_TIMEOUT=10

# API ключи брокеров для песочницы (T-Bank / Alfa) - Вписывать только тестовые ключи!
BROKER_SANDBOX_API_KEY=your_sandbox_key_here